rules_version = '2';

// =====================================================================
// ALES MASABA ANIMAL FEED - Firestore Security Rules
// =====================================================================
// NENDA: Firebase Console -> Firestore Database -> Rules -> bandika hii
// yote -> Publish.
//
// MSINGI WA ULINZI:
//  - Super Admin (role == 'super_admin'): anaona/anabadilisha kila kitu.
//  - Cashier (role == 'cashier'): anaweza kuuza (create sales, punguza
//    stock, ongeza wateja/malipo) lakini HAWEZI kusoma bei ya ununuzi
//    (buying_price), ripoti za jumla za mauzo ya wengine, wala orodha ya
//    watumiaji wengine.
//
// TAARIFA: UI ya programu (Flutter) tayari inaficha vitufe/skrini hizi kwa
// Cashier, lakini Security Rules hapa chini ndizo ULINZI HALISI - bila
// hizi, mtu mwenye ujuzi angeweza kusoma data moja kwa moja kupitia
// Firestore API bila kupitia app.
// =====================================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // ------------------------------------------------------------------
    // Vitendaji vya msaada
    // ------------------------------------------------------------------
    function isSignedIn() {
      return request.auth != null;
    }

    function myRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isSuperAdmin() {
      return isSignedIn() && myRole() == 'super_admin';
    }

    function isActiveUser() {
      return isSignedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isActive == true;
    }

    // ------------------------------------------------------------------
    // users/{uid} - Wasifu wa mtumiaji (Super Admin / Cashier)
    // ------------------------------------------------------------------
    match /users/{uid} {
      // Kila mtumiaji anaweza kusoma wasifu wake mwenyewe; Super Admin
      // anaweza kusoma wasifu wa wote (kwa orodha ya Cashier).
      allow read: if isSignedIn() && (request.auth.uid == uid || isSuperAdmin());
      // Uundaji wa akaunti mpya (Super Admin anaposajili Cashier, au
      // "bootstrap" ya Super Admin wa kwanza) unafanyika na Firebase Auth
      // SDK moja kwa moja (createUserWithEmailAndPassword humpa mtumiaji
      // huyo ruhusa ya kuandika doc yake mwenyewe mara moja).
      allow create: if isSignedIn() && request.auth.uid == uid;
      allow create: if isSuperAdmin();
      // Kubadilisha (isActive, branchName, n.k.) - Super Admin pekee,
      // isipokuwa mtumiaji anaweza kubadilisha baadhi ya taarifa zake mwenyewe.
      allow update: if isSuperAdmin() ||
        (isSignedIn() && request.auth.uid == uid &&
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['fullName', 'email']));
      allow delete: if isSuperAdmin();
    }

    // ------------------------------------------------------------------
    // categories/{id}
    // ------------------------------------------------------------------
    match /categories/{id} {
      allow read: if isActiveUser();
      allow write: if isSuperAdmin();
    }

    // ------------------------------------------------------------------
    // products/{id}
    // ------------------------------------------------------------------
    match /products/{id} {
      // Cashier anaweza kusoma bidhaa (jina, bei ya kuuzia, kiasi) ili
      // auze - lakini si "buying_price" (bei ya ununuzi/faida). Kwa
      // Firestore, field-level read restriction si rahisi kwa hati nzima
      // moja kwa moja; njia salama zaidi ni kutovionyesha upande wa UI
      // (tumeshafanya hivyo kwenye app) - Rules hapa zinalinda WRITE.
      allow read: if isActiveUser();

      // Super Admin: CRUD kamili (bei, jina, kufuta, n.k.)
      allow create, delete: if isSuperAdmin();
      allow update: if isSuperAdmin() ||
        // Cashier anaruhusiwa KUBADILISHA 'quantity' na 'updated_at' TU
        // (hii ndiyo inayotokea wakati wa mauzo - punguza stock).
        (isActiveUser() &&
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['quantity', 'updated_at']));
    }

    // ------------------------------------------------------------------
    // customers/{id} - Cashier na Super Admin wote wanahitaji kuandika/
    // kusoma wateja ili kuuza kwa mkopo.
    // ------------------------------------------------------------------
    match /customers/{id} {
      allow read, create, update: if isActiveUser();
      allow delete: if isSuperAdmin();
    }

    // ------------------------------------------------------------------
    // sales/{id} - Mauzo
    // ------------------------------------------------------------------
    match /sales/{id} {
      // Cashier anaona TU mauzo aliyoyafanya yeye mwenyewe (user_id == uid
      // yake). Super Admin anaona yote (Ripoti).
      allow read: if isSuperAdmin() ||
        (isActiveUser() && resource.data.user_id == request.auth.uid);
      allow create: if isActiveUser() && request.resource.data.user_id == request.auth.uid;
      allow update, delete: if isSuperAdmin();
    }

    // ------------------------------------------------------------------
    // credit_sales/{id} - Madeni ya wateja
    // ------------------------------------------------------------------
    match /credit_sales/{id} {
      allow read: if isSuperAdmin() ||
        (isActiveUser() && resource.data.created_by == request.auth.uid);
      allow create: if isActiveUser() && request.resource.data.created_by == request.auth.uid;
      // Kurekodi malipo (amount_paid, status) - watumiaji wote hai
      // wanaruhusiwa (mteja anaweza kulipa deni kwa Cashier yeyote).
      allow update: if isActiveUser();
      allow delete: if isSuperAdmin();

      // payments/{paymentId} - subcollection ya historia ya malipo
      match /payments/{paymentId} {
        allow read: if isSuperAdmin() ||
          (isActiveUser() &&
            get(/databases/$(database)/documents/credit_sales/$(id)).data.created_by == request.auth.uid);
        allow create: if isActiveUser();
        allow update, delete: if isSuperAdmin();
      }
    }

    // ------------------------------------------------------------------
    // expenses/{id} - Matumizi ya biashara: Super Admin PEKEE (Ripoti za
    // fedha si za Cashier).
    // ------------------------------------------------------------------
    match /expenses/{id} {
      allow read, write: if isSuperAdmin();
    }

    // ------------------------------------------------------------------
    // activity_logs/{id} - Kumbukumbu za matukio
    // ------------------------------------------------------------------
    match /activity_logs/{id} {
      allow read: if isSuperAdmin();
      allow create: if isActiveUser();
      allow update, delete: if false;
    }
  }
}
